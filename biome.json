{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "includes": [
      "apps/**/*.ts",
      "apps/**/*.tsx",
      "packages/**/*.ts",
      "*.json",
      "*.ts",
      "!apps/api/src/generated",
      "!apps/mobile/.expo",
      "!apps/mobile/expo-env.d.ts",
      "!apps/mobile/dist",
      "!packages/**/dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  }
}
