{
  "expo": {
    "name": "Smart Ant",
    "slug": "smartant",
    "scheme": "smart-ant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/smartant-mark.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartant.app"
    },
    "android": {
      "package": "com.smartant.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F1",
        "foregroundImage": "./assets/smartant-mark.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/smartant-mark.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que SmartAnt use Face ID para proteger tu sesión."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF7F1",
          "image": "./assets/smartant-mark.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-status-bar",
        {
          "hidden": true
        }
      ],
      [
        "expo-navigation-bar",
        {
          "hidden": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b68d45a-2cf7-48c2-9abd-a0cebf3a0725"
      }
    },
    "owner": "fria"
  }
}
