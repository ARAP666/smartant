generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  currency     String    @default("CRC")
  timeZone     String    @default("America/Costa_Rica") @map("time_zone")
  incomes      Income[]
  salary       Salary?
  sessions     Session[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Salary {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @unique @db.Uuid @map("user_id")
  amountMinor BigInt      @map("amount_minor")
  frequency   String
  nextDate    DateTime    @db.Date @map("next_date")
  pausedAt    DateTime?   @map("paused_at")
  runs        SalaryRun[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("salaries")
}

model SalaryRun {
  id        String   @id @default(uuid()) @db.Uuid
  salaryId  String   @db.Uuid @map("salary_id")
  incomeId  String   @unique @db.Uuid @map("income_id")
  periodKey String   @map("period_key")
  createdAt DateTime @default(now()) @map("created_at")
  income    Income   @relation(fields: [incomeId], references: [id], onDelete: Cascade)
  salary    Salary   @relation(fields: [salaryId], references: [id], onDelete: Cascade)

  @@unique([salaryId, periodKey])
  @@map("salary_runs")
}

model Income {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  amountMinor BigInt   @map("amount_minor")
  date        DateTime @db.Date
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  salaryRun   SalaryRun?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("incomes")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
