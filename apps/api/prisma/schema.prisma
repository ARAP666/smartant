generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  currency     String    @default("CRC")
  timeZone     String    @default("America/Costa_Rica") @map("time_zone")
  budgets      Budget[]
  expenses     Expense[]
  incomes      Income[]
  pendingMovements PendingMovement[]
  receiptAttachments ReceiptAttachment[]
  salary       Salary?
  savingsGoals SavingsGoal[]
  sessions     Session[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model PendingMovement {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  amountMinor BigInt   @map("amount_minor")
  date        DateTime @db.Date
  description String
  category    String
  status      String   @default("PENDING")
  expense     Expense?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("pending_movements")
}

model Expense {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @db.Uuid @map("user_id")
  pendingMovementId String           @unique @db.Uuid @map("pending_movement_id")
  idempotencyKey    String           @unique @map("idempotency_key")
  amountMinor       BigInt           @map("amount_minor")
  date              DateTime         @db.Date
  description       String
  category          String
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  pendingMovement   PendingMovement  @relation(fields: [pendingMovementId], references: [id], onDelete: Cascade)
  receiptAttachment ReceiptAttachment?
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("expenses")
}

model ReceiptAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid @map("user_id")
  expenseId    String   @unique @db.Uuid @map("expense_id")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  data         Bytes
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  expense      Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("receipt_attachments")
}

model SavingsGoal {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  amountMinor BigInt   @map("amount_minor")
  period      String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, period, active])
  @@map("savings_goals")
}

model Budget {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  amountMinor BigInt   @map("amount_minor")
  period      String
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, period, category])
  @@map("budgets")
}

model Salary {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @unique @db.Uuid @map("user_id")
  amountMinor BigInt      @map("amount_minor")
  frequency   String
  nextDate    DateTime    @db.Date @map("next_date")
  pausedAt    DateTime?   @map("paused_at")
  runs        SalaryRun[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("salaries")
}

model SalaryRun {
  id        String   @id @default(uuid()) @db.Uuid
  salaryId  String   @db.Uuid @map("salary_id")
  incomeId  String   @unique @db.Uuid @map("income_id")
  periodKey String   @map("period_key")
  createdAt DateTime @default(now()) @map("created_at")
  income    Income   @relation(fields: [incomeId], references: [id], onDelete: Cascade)
  salary    Salary   @relation(fields: [salaryId], references: [id], onDelete: Cascade)

  @@unique([salaryId, periodKey])
  @@map("salary_runs")
}

model Income {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  amountMinor BigInt   @map("amount_minor")
  date        DateTime @db.Date
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  salaryRun   SalaryRun?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("incomes")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
